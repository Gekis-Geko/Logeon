{% extends theme_shell('game', 'app/layouts/layout.twig') %}

{% block content %}

<main id="equips-page" class="row g-3 ui-page pb-3">
    <header class="col-12">
        <div class="card">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <h1 class="h4 mb-1">Equipaggiamento</h1>
                    <p class="text-muted mb-0">Gestisci gli slot del personaggio e scegli gli oggetti equipaggiabili per categoria.</p>
                </div>
            </div>
        </div>
    </header>

    <aside class="col-12 col-xl-4">
        <div class="card">
            <div class="card-header">
                <h2 class="h6 mb-0">Slot equipaggiati</h2>
            </div>
            <div class="card-body">
                <div class="equip-slots-grid" data-role="equip-slots-grid">
                    <div class="text-muted small" data-role="equip-slots-loading">Caricamento slot...</div>
                </div>
            </div>
        </div>
    </aside>

    <section class="col-12 col-xl-8">
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs pt-2" id="equipsTypeTab" role="tablist" data-role="equip-tabs">
                    <li class="nav-item" role="presentation">
                        <span class="nav-link text-muted">Caricamento categorie...</span>
                    </li>
                </ul>
            </div>
            <div class="card-body p-2 p-md-3">
                <div class="tab-content" id="equipsTypeTabContent" data-role="equip-tab-content">
                    <div class="text-muted small p-2">Caricamento elenco equipaggiabile...</div>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}

