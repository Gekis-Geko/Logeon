<div class="modal fade mail-modal" id="inbox-modal" tabindex="-1" role="dialog" aria-hidden="true" data-requires-auth>
    <div class="modal-dialog modal-fullscreen" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div class="d-flex align-items-center gap-2">
                    <span class="bi bi-envelope-paper"></span>
                    <h5 class="modal-title mb-0">Messaggi</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
            </div>
            <div class="modal-body p-0 mail-body">
                <div class="container-fluid h-100">
                    <div class="row g-0 h-100">
                        <div class="col-lg-4 mail-sidebar border-end">
                            <div class="p-3 h-100 d-flex flex-column">
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <h6 class="mb-0">Conversazioni</h6>
                                    <span class="badge text-bg-light mail-count" data-role="inbox-thread-count">0</span>
                                </div>
                                <div class="input-group mb-3">
                                    <span class="input-group-text bg-white"><span class="bi bi-search"></span></span>
                                    <input type="text" class="form-control" placeholder="Cerca..." data-role="inbox-search">
                                </div>
                                <button type="button" class="btn btn-sm btn-primary mb-3" data-role="inbox-compose-btn" data-requires-auth>
                                    <span class="bi bi-plus-lg me-1"></span> Nuova conversazione
                                </button>
                                <div id="inbox-threads" class="list-group mail-threads flex-grow-1" data-role="inbox-threads">
                                    <div class="list-group-item text-muted">Caricamento conversazioni...</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-8">
                            <div class="p-3 h-100">
                                <div id="inbox-empty" class="card card-body mail-empty" data-role="inbox-empty">
                                    <h6>Seleziona una conversazione</h6>
                                    <p class="text-muted">Scegli una conversazione dalla lista a sinistra.</p>
                                </div>

                                <div id="inbox-compose" class="d-none mail-compose" data-role="inbox-compose">
                                    <div class="mail-compose__header">
                                        <div>
                                            <h6 class="mb-1">Nuova conversazione</h6>
                                            <small class="text-muted">Scrivi un nuovo messaggio.</small>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-primary" data-role="inbox-compose-cancel">Annulla</button>
                                    </div>
                                    <form id="inbox-compose-form" class="mt-3" data-requires-auth>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Destinatario</label>
                                                <input type="hidden" name="recipient_id" data-role="compose-recipient-id">
                                                <input type="text" name="recipient_name" class="form-control" data-role="compose-recipient-name" placeholder="Nome personaggio" autocomplete="off" required>
                                                <div class="list-group mt-2 d-none" data-role="compose-recipient-suggestions"></div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Tipo</label>
                                                <input type="hidden" name="message_type" value="on" data-role="compose-message-type">
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Oggetto</label>
                                                <input type="text" name="subject" class="form-control" placeholder="Titolo del filone" required>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Messaggio</label>
                                                <textarea name="body" class="form-control" rows="5" placeholder="Scrivi la tua missiva..." required></textarea>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end mt-3">
                                            <button type="button" class="btn btn-primary" data-role="inbox-compose-send" data-requires-auth>Invia</button>
                                        </div>
                                    </form>
                                </div>

                                <div id="inbox-thread" class="d-none mail-thread" data-role="inbox-thread">
                                    <div class="mail-thread__header">
                                        <div>
                                            <h5 class="mb-0" data-role="inbox-thread-subject">Senza oggetto</h5>
                                            <small class="text-muted" data-role="inbox-thread-participants"></small>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-danger" data-role="inbox-delete-thread" title="Elimina conversazione per te">
                                                <span class="bi bi-trash"></span>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-primary" data-role="inbox-new-thread">Nuova conversazione</button>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-center mb-2">
                                        <button type="button" class="btn btn-sm btn-outline-primary d-none" data-role="inbox-load-more">Carica precedenti</button>
                                    </div>
                                    <div id="inbox-message-list" class="mail-thread__messages" data-role="inbox-message-list"></div>
                                    <form id="inbox-message-form" class="mail-thread__reply" data-role="inbox-message-form" data-requires-auth>
                                        <div class="input-group">
                                            <input type="hidden" name="message_type" value="on" data-role="reply-message-type">
                                            <textarea name="body" class="form-control" rows="3" placeholder="Scrivi la risposta..." data-role="inbox-message-input"></textarea>
                                            <button type="submit" class="btn btn-primary" data-requires-auth>Invia</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <template name="template_inbox_thread">
                <a href="#" class="list-group-item list-group-item-action mail-thread-item d-flex gap-3 align-items-start">
                    <div class="mail-thread-item__content flex-grow-1">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge text-bg-dark" name="type">ON</span>
                                <h6 class="mb-0 mail-thread-item__subject" name="subject"></h6>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted" name="date"></small>
                                <span class="badge text-bg-danger d-none" name="unread"></span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between">
                            <small class="text-muted" name="name"></small>
                            <small class="text-muted mail-thread-item__body" name="body"></small>
                        </div>
                    </div>
                </a>
            </template>
        </div>
    </div>
</div>



