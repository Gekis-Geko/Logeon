<div class="modal fade" id="profile-attributes-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-5 text-center mt-3 mb-3">Gestione attributi personaggio</h4>
                <h6 class="text-center text-muted">Editor staff: modifica valori base/override e ricalcola derivati.</h6>
                <hr class="my-4" />

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                    <div class="small text-muted">Target: personaggio #<span data-role="profile-attributes-edit-character-id">{{ character_id }}</span></div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary" data-action="profile-attributes-recompute">
                            <i class="bi bi-arrow-repeat me-1"></i>Ricalcola
                        </button>
                        <button type="button" class="btn btn-sm btn-primary" data-action="profile-attributes-save">
                            <i class="bi bi-save me-1"></i>Salva valori
                        </button>
                    </div>
                </div>

                <div class="alert alert-secondary d-none" data-role="profile-attributes-edit-empty">Nessun attributo disponibile.</div>

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0" id="profile-attributes-edit-table">
                        <thead>
                            <tr>
                                <th>Attributo</th>
                                <th style="width: 120px;">Gruppo</th>
                                <th style="width: 110px;">Derivato</th>
                                <th style="width: 150px;">Valore base</th>
                                <th style="width: 170px;">Override</th>
                                <th style="width: 150px;">Effettivo</th>
                            </tr>
                        </thead>
                        <tbody data-role="profile-attributes-edit-body"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

