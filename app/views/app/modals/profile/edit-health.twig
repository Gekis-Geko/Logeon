<div class="modal fade" id="profile-health-modal" tabindex="-1" aria-hidden="true" data-requires-staff>
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-6 text-center mt-3 mb-2">Modifica salute/vita</h4>
                <h6 class="text-center text-muted">Solo staff: aggiorna salute attuale e massima del personaggio.</h6>
                <hr class="my-4" />

                <form id="profile-health-form">
                    <input type="hidden" name="character_id">
                    <div class="form-group mb-3">
                        <label class="form-label">Salute attuale</label>
                        <input type="number" name="health" class="form-control" step="0.01" min="0" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Salute massima</label>
                        <input type="number" name="health_max" class="form-control" step="0.01" min="1" required>
                        <div class="form-text">Solo staff (master, moderatori, admin) puo modificare questi valori.</div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annulla</button>
                        <button type="submit" class="btn btn-primary" data-health-save>Salva</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

