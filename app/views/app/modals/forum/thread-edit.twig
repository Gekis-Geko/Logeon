<div class="modal fade"
     id="thread-edit-modal"
     tabindex="-1"
     role="dialog"
     aria-labelledby="dialog-label"
     aria-hidden="true"
     data-requires-auth
     data-id="{{ id|default('')|e('html_attr') }}"
     data-forum-id="{{ forum_id|default('')|e('html_attr') }}"
     data-father-id="{{ father_id|default('')|e('html_attr') }}"
     data-character-id="{{ character_id|default('')|e('html_attr') }}">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>

                <h4 class="display-6 mt-3 mb-3">Thread</h4>
                <h6 class="text-muted">Crea o modifica un thread del forum</h6>

                <hr class="my-4" />

                <div class="d-grid gap-2 col-12 mx-auto my-4">
                    <form id="thread-edit-modal-form">

                        <div class="form-floating my-3">
                            <input type="text" name="title" class="form-control" placeholder="Titolo del thread">
                            <label>Titolo del thread</label>
                        </div>
                        <div class="form-group my-3">
                            <label>Corpo del thread</label>
                            <textarea id="thread_edit" name="body" class="richtext-editor"></textarea>
                        </div>

                        <input type="hidden" name="id">
                        <input type="hidden" name="character_id">
                        <input type="hidden" name="forum_id">
                        <input type="hidden" name="father_id">

                        <hr class="w-75 mx-auto" />

                        <div class="d-grid gap-2 col-6 mx-auto my-5">
                            <button type="button" class="btn btn-primary btn-block btn-round" data-action="thread-edit-send" data-requires-auth>Confermo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>



