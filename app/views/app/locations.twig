{% extends theme_shell('game', 'app/layouts/layout.twig') %}

{% block content %}
<div class="container">
    {% set map_breadcrumb = map_breadcrumb|default([]) %}
    {% set map_parent_id = map_parent_id|default(null) %}
    <section id="locations-page" class="row ui-page" data-map-id="{{ map_id|e('html_attr') }}">
        <div class="col-12">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb small mb-2">
                    <li class="breadcrumb-item"><a href="/game/maps/">Mappe</a></li>
                    {% for crumb in map_breadcrumb %}
                        {% if loop.last %}
                            <li class="breadcrumb-item active" aria-current="page">{{ crumb.name }}</li>
                        {% else %}
                            <li class="breadcrumb-item"><a href="/game/maps/{{ crumb.id }}">{{ crumb.name }}</a></li>
                        {% endif %}
                    {% endfor %}
                </ol>
            </nav>
        </div>
        <header class="col-12 d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="display-6 mb-1" name="map_name"></h4>
            </div>
            <div>
                <a class="btn btn-sm btn-outline-secondary" href="{% if map_parent_id %}/game/maps/{{ map_parent_id }}{% else %}/game/maps/{% endif %}"><i class="bi bi-arrow-left-short"></i> {% if map_parent_id %}Torna alla mappa padre{% else %}Torna alle mappe{% endif %}</a>
            </div>
        </header>
        <section id="map-child-maps-section" class="col-12 mb-4 d-none">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">Sottomappe</h5>
            </div>
            <div id="map-child-maps" class="row g-3"></div>
        </section>
        <article class="col-12">
            <div id="map-visual" class="d-none mb-4">
                <div class="position-relative w-100">
                    <img id="map-visual-image" class="img-fluid w-100" alt="">
                    <div id="map-visual-pins" class="position-absolute top-0 start-0 w-100 h-100"></div>
                </div>
            </div>
            <section id="locations-page-section" class="d-none">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Luoghi</h5>
                </div>
                <div id="locations-page-body" class="row g-3"></div>
            </section>
            <div id="locations-page-empty" class="alert alert-info d-none mb-0">Questa mappa non contiene ancora luoghi o sottomappe.</div>
        </article>
    </section>
</div>

<template name="template_child_map_card">
    <article class="col-md-6 col-xl-4">
        <div class="card h-100">
            <img class="card-img-top map-child-image" alt="">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2">
                    <img class="map-child-icon d-none" width="28" height="28" alt="">
                    <h5 class="card-title mb-0 map-child-title"></h5>
                    <span class="badge text-bg-warning map-child-mobile-badge d-none">Mobile</span>
                </div>
                <p class="card-text mt-2 map-child-description"></p>
                <div class="small text-muted map-child-status"></div>
            </div>
            <div class="card-footer text-end">
                <a href="#" class="btn btn-primary map-child-link">Apri mappa <i class="bi bi-arrow-right-short"></i></a>
            </div>
        </div>
    </article>
</template>

<template name="template_locations_list">
    <article class="col-md-4">
        <div class="card h-100">
            <img class="card-img-top">
            <div class="card-body">
                <h5 class="card-title"></h5>
                <p class="card-text"></p>
                <div class="location-meta small text-muted d-flex justify-content-between align-items-center mt-2">
                    <span class="location-capacity"></span>
                    <span class="badge bg-warning text-dark d-none location-badge-full">Piena</span>
                </div>
                <div class="text-end">
                    <a href="#" class="btn btn-primary location-link">Entra <i class="bi bi-arrow-right-short"></i></a>
                </div>
            </div>
        </div>
    </article>
</template>
{% endblock %}