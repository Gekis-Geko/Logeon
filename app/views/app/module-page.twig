{% extends theme_shell('game', 'app/layouts/layout.twig') %}

{% block content %}
{% set slot_name = module_page_slot|default('') %}
{% set slot_html = slot_name ? module_slot(slot_name) : '' %}

{% if slot_html is not empty %}
    {{ slot_html }}
{% else %}
    <main class="container-fluid py-3">
        <div class="alert alert-info mb-0">
            Il contenuto del modulo non e disponibile in questa installazione.
        </div>
    </main>
{% endif %}
{% endblock %}


