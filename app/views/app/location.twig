{% extends theme_shell('game', 'app/layouts/layout.twig') %}

{% block content %}
{% set is_staff = session('user_is_administrator') == 1 or session('user_is_moderator') == 1 or session('user_is_master') == 1 %}

<section id="location-page" class="row g-3 ui-page location-page-bootstrap">
    <header class="col-12 border-bottom pb-2">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <p class="small text-uppercase text-muted fw-semibold mb-1"> <i class="bi bi-dot text-info"></i> {{ map_name|default('Mappa') }}</p>
                <h1 class="h4 mb-0">{{ location_name|default('Luogo') }}</h1>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-sm btn-primary" href="/game/maps/{{ map_id }}">
                    <i class="bi bi-arrow-left-short me-1"></i>Torna alla mappa
                </a>
                <button class="btn btn-sm btn-outline-secondary"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#location-description-modal">
                    <i class="bi bi-book me-1"></i>Descrizione
                </button>
                <button id="location-quick-tools-toggle"
                        class="btn btn-sm btn-outline-secondary"
                        type="button"
                        aria-controls="location-quick-tools"
                        aria-expanded="true">
                    <i class="bi bi-lightning-charge me-1"></i>
                    <span class="location-quick-tools-toggle__label">Nascondi azioni rapide</span>
                </button>
                <button id="location-utility-toggle"
                        class="btn btn-sm btn-outline-secondary"
                        type="button"
                        aria-controls="location-utility-column"
                        aria-expanded="true">
                    <i class="bi bi-layout-sidebar-inset me-1"></i>
                    <span class="location-utility-toggle__label"><span>Nascondi strumenti</span></span>
                </button>
            </div>
        </div>
    </header>

    <div class="col-12 mt-0">
        <div id="location-quick-tools" class="card shadow-sm">
            <div class="card-body py-2">
                <div class="d-flex flex-nowrap flex-lg-wrap align-items-center gap-2 overflow-auto location-toolbar-scroll">
                    <button class="btn btn-sm btn-outline-secondary"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#location-utils-modal">
                        <i class="bi bi-person-rolodex me-1"></i>Utilita
                    </button>
                    <button class="btn btn-sm btn-outline-secondary"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#location-scene-launcher-modal"
                            data-requires-auth>
                        <i class="bi bi-magic me-1"></i>Azioni scena
                    </button>
                    <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#location-drops-modal">
                        <i class="bi bi-box-seam"></i>
                        <span>Oggetti a terra</span>
                        <span id="location-drops-count-badge" class="badge text-bg-danger d-none">0</span>
                    </button>
                    <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                            type="button"
                            data-whispers-hub-open
                            data-requires-auth>
                        <i class="bi bi-chat-dots"></i>
                        <span>Sussurri</span>
                        <span class="badge text-bg-danger d-none" data-role="whispers-unread-badge" data-hide-when-zero="1">0</span>
                    </button>
                    {% if show_jobs_board|default(false) %}
                    <a class="btn btn-sm btn-outline-secondary" href="/game/jobs/location/{{ location_id }}">
                        <i class="bi bi-briefcase me-1"></i>Bacheca lavori
                    </a>
                    {% endif %}
                    {% include 'app/weather/location-quick-tools.twig' %}
                    {{ slot('game.location.quick_tools') }}
                    <button class="btn btn-sm btn-outline-secondary ms-lg-auto"
                            type="button"
                            data-action="chat-archive-create-open"
                            data-requires-auth>
                        <i class="bi bi-archive me-1"></i>Salva giocata
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 mt-2">
        <div class="row g-3 align-items-start">
            <aside id="location-context-column" class="col-12 col-xl-2 order-2 order-xl-1 mt-0">
                <div class="d-flex flex-column gap-3 location-sticky-column">
                    <div id="location-scenes-panel" class="card shadow-sm d-none" data-bs-theme="dark">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-calendar-event me-1"></i>Scena</span>
                            <span class="badge text-bg-danger">ATTIVA</span>
                        </div>
                        <div id="location-scenes-list" class="card-body p-2"></div>
                    </div>

                    <div id="location-npcs-panel" class="card shadow-sm d-none">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-person-badge me-1"></i>PNG</span>
                            <button type="button"
                                    class="btn btn-sm btn-link p-0 text-secondary"
                                    data-action="location-npcs-toggle"
                                    aria-expanded="false">
                                <i class="bi bi-chevron-down" id="location-npcs-toggle-icon"></i>
                            </button>
                        </div>
                        <div id="location-npcs-list" class="card-body p-2 d-none">
                            <p class="text-muted small mb-0">
                                <i class="bi bi-chat-left-dots me-1"></i>Usa <code>/png @NomePNG testo</code> per parlare come un PNG.
                            </p>
                        </div>
                    </div>

                    <div id="location-position-tags-panel" class="card shadow-sm d-none">
                        <div class="card-header py-2">
                            <i class="bi bi-geo-alt me-1"></i>Posizioni
                        </div>
                        <div id="location-position-tags-list" class="card-body p-2">
                            <p class="text-muted small mb-0">Nessuna posizione definita.</p>
                        </div>
                    </div>
                </div>
            </aside>

            <div id="location-chat-column" class="col-12 col-xl-8 d-flex flex-column order-1 order-xl-2 mt-0">
                <div id="location-chat-card" class="shadow-sm flex-grow-1 mb-2">
                    <div class="p-0 d-flex flex-column">
                        <div id="chat_display">
                            <div id="chat_messages"></div>
                            <div id="chat_empty" class="alert alert-info d-none text-center m-3">
                                La scena e silenziosa.
                            </div>
                        </div>
                    </div>
                </div>

                <div id="chat_action_character" class="card shadow-sm" data-requires-auth>
                    <div class="card-body overflow-visible">
                        <div class="row g-3 align-items-stretch">
                            <div class="col-12 col-lg">
                                <div class="position-relative h-100">
                                    <div class="list-group chat-command-suggest d-none"></div>
                                    <textarea name="chat_body"
                                              class="form-control location-chat-textarea h-100"
                                              placeholder="Scrivi l'azione del tuo personaggio..."
                                              maxlength=""
                                              rows="3"></textarea>
                                </div>
                            </div>

                            <div class="col-12 col-lg-3 col-xxl-2">
                                <div class="d-grid gap-3 h-100">
                                    <div class="position-relative">
                                        <label class="form-label small text-uppercase text-muted fw-semibold mb-1" for="location-tag-position">Posizione o tag</label>
                                        <input id="location-tag-position"
                                               type="text"
                                               name="tag_position"
                                               class="form-control"
                                               placeholder="[Posizione/Tag]"
                                               autocomplete="off">
                                        <div id="location-tag-position-suggestions"
                                             class="list-group location-tag-suggest d-none"></div>
                                    </div>
                                    <div class="d-flex gap-2 mt-auto">
                                        <button class="btn btn-sm btn-outline-secondary flex-fill"
                                                type="button"
                                                data-action="location-roll"
                                                data-requires-auth>Dado</button>
                                        <button class="btn btn-sm btn-primary flex-fill"
                                                type="button"
                                                data-chat-send
                                                data-requires-auth>Invia</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" name="location_id" value="{{ location_id }}">
                        <input type="hidden" name="character_id" value="{{ session('character_id') }}">
                        <input type="hidden" name="location_tag_id" value="">
                        <input type="hidden" name="location_tag_label" value="">
                        <input type="hidden" name="location_tag_detail" value="">
                        <input type="hidden" name="location_tag_display" value="">
                    </div>
                </div>
            </div>

            <div id="location-utility-column" class="col-12 col-xl-2 order-3 mt-0">
                <aside id="chat-utils"
                       class="offcanvas-xl offcanvas-end"
                       tabindex="-1"
                       aria-labelledby="location-utility-panel-title"
                       data-bs-scroll="true">
                    <div class="offcanvas-header d-xl-none border-bottom">
                        <h5 class="offcanvas-title" id="location-utility-panel-title">Strumenti scena</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Chiudi"></button>
                    </div>
                    <div class="offcanvas-body p-0">
                        <div class="d-flex flex-column gap-3 location-sticky-column p-0">
                            <div id="location-quick-vitals" class="card shadow-sm">
                                <div class="card-header py-2">
                                    <i class="bi bi-person-circle me-1"></i>PG
                                </div>
                                <div class="card-body p-3">
                                    <div class="vstack gap-3">
                                        <div>
                                            <div class="d-flex justify-content-between align-items-center gap-2 small mb-2">
                                                <span class="fw-semibold"><i class="bi bi-heart-pulse me-1"></i>Salute</span>
                                                <span><b id="location-profile-hp-current">0</b> / <b id="location-profile-hp-max">0</b></span>
                                            </div>
                                            <div class="progress mb-2" role="progressbar" aria-label="Salute personaggio" aria-valuemin="0" aria-valuemax="100">
                                                <div id="location-profile-hp-bar" class="progress-bar bg-danger" role="progressbar" aria-valuenow="0"></div>
                                            </div>
                                            <div class="d-flex justify-content-between gap-2 small text-muted">
                                                <span>Integrita: <span id="location-profile-hp-percent">N/D</span></span>
                                                <span class="badge text-bg-secondary" id="location-profile-hp-state">Sconosciuto</span>
                                            </div>
                                            <span id="location-profile-hp-label" class="d-none">N/D</span>
                                        </div>

                                        <div>
                                            <div class="d-flex justify-content-between align-items-center gap-2 small mb-2">
                                                <span class="fw-semibold"><i class="bi bi-stars me-1"></i>Esperienza</span>
                                                <span><b id="location-profile-exp-current">0</b> / <b id="location-profile-exp-max">100</b></span>
                                            </div>
                                            <div class="progress mb-2" role="progressbar" aria-label="Esperienza personaggio" aria-valuemin="0" aria-valuemax="100">
                                                <div id="location-profile-exp-bar" class="progress-bar bg-primary" role="progressbar" aria-valuenow="0"></div>
                                            </div>
                                            <div class="d-flex justify-content-between gap-2 small text-muted">
                                                <span>Progresso: <span id="location-profile-exp-percent">N/D</span></span>
                                                <span>Totale: <span id="location-profile-exp-total">0</span></span>
                                            </div>
                                            <span id="location-profile-exp-label" class="d-none">N/D</span>
                                        </div>
                                    </div>

                                    <div id="location-profile-attributes-summary" class="border-top pt-3 mt-3 d-none">
                                        <div class="small fw-semibold mb-2"><i class="bi bi-sliders me-1"></i>Attributi</div>
                                        <div class="small d-grid gap-1" id="location-profile-attributes-list"></div>
                                    </div>
                                </div>
                            </div>

                            <div id="location-conflicts-panel" class="card shadow-sm">
                                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-fire me-1"></i>Conflitti</span>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#location-conflicts-modal">
                                        Apri
                                    </button>
                                </div>
                                <div class="card-body p-2">
                                    <div class="small text-muted mb-2" id="location-conflicts-panel-meta">Caricamento conflitti...</div>
                                    <div id="location-conflicts-panel-empty" class="small text-muted">Nessun conflitto attivo o proposta in attesa.</div>
                                    <div id="location-conflicts-panel-list" class="list-group list-group-flush d-none"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>
</section>

{% include 'app/modals/location/utils.twig' %}
{% include 'app/modals/location/scene-launcher.twig' %}
{% include 'app/modals/location/drops.twig' %}
{% include 'app/modals/location/conflicts.twig' %}
{% include 'app/weather/location-modal.twig' %}
{{ slot('game.location.modals') }}
{% include 'app/modals/location/whispers-hub.twig' %}
{% include 'app/modals/location/description.twig' %}
{% include 'app/modals/location/report-message.twig' %}
{% include 'app/modals/location/chat-archive-create.twig' %}

<template name="template_location_message_other">
    <article class="location-chat-message location-chat-message--other chat-message d-flex align-items-start gap-3 border rounded-3 p-3 mb-2">
        <div class="location-chat-message__avatar flex-shrink-0">
            <img class="chat-avatar" alt="">
        </div>
        <div class="location-chat-message__content flex-grow-1">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                <h6 class="chat-meta mb-0 small text-muted fw-semibold"></h6>
                <button type="button" class="btn btn-sm btn-outline-danger chat-report chat-report-compact">
                    <i class="bi bi-flag" data-bs-toggle="tooltip" data-bs-title="Segnala giocatore"></i> Segnala
                </button>
            </div>
            <div class="location-chat-message__body">
                <div class="chat-body"></div>
            </div>
        </div>
    </article>
</template>

<template name="template_location_message_me">
    <article class="location-chat-message location-chat-message--me chat-message d-flex align-items-start justify-content-end gap-3 border rounded-3 p-3 mb-2">
        <div class="location-chat-message__content flex-grow-1">
            <div class="mb-2">
                <h6 class="chat-meta mb-0 small text-muted fw-semibold"></h6>
            </div>
            <div class="location-chat-message__body">
                <div class="chat-body"></div>
            </div>
        </div>
        <div class="location-chat-message__avatar flex-shrink-0">
            <img class="chat-avatar" alt="">
        </div>
    </article>
</template>

<template name="template_location_message_system">
    <article class="location-chat-message location-chat-message--system chat-message alert alert-secondary text-center py-3 px-3 mb-2">
        <div class="chat-body"></div>
    </article>
</template>

{% endblock %}
