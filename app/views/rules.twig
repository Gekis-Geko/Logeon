{% extends theme_shell('public', 'layouts/layout.twig') %}

{% block content %}
<main>
    <header class="py-5 text-center docs-hero">
        <div class="bg-light my-5 py-4">
            <h1 class="display-3 my-4">Regolamento</h1>
            <h2 class="display-6 text-muted mb-4">Leggi il regolamento e scopri cosa puoi fare all'interno del gioco</h2>
        </div>
    </header>
    <div class="container my-5">
        {% if view_mode == 'monolithic' %}
        <div class="docs-page docs-page--monolithic" id="rules-page" data-view-mode="monolithic">
            <div class="card card-body">
                <div data-role="docs-content"></div>
            </div>
        </div>
        {% else %}
        <div class="row docs-page" id="rules-page" data-view-mode="navigation">
            <div class="col-4 col-lg-3">
                <div class="mb-3">
                    <input type="text" class="form-control form-control-sm" data-role="docs-filter" placeholder="Cerca articolo...">
                </div>
                <ul class="nav flex-column" data-role="docs-nav" role="tablist"></ul>
            </div>
            <div class="col-8 col-lg-9">
                <div class="card card-body">
                    <div class="tab-content" data-role="docs-content"></div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</main>

{% include 'sys/modals/license.twig' %}

{% endblock %}
