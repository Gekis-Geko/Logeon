<aside class="offcanvas offcanvas-start" tabindex="-1" id="mainAsideCanvas" aria-labelledby="mainAsideCanvasTitle">
    <div class="offcanvas-header">
        <a class="d-flex align-items-center gap-2 text-decoration-none" href="/">
            <img src="{{ APP.brand_logo_icon }}" alt="{{ APP.name }}" height="32">
            <img src="{{ APP.brand_logo_wordmark }}" alt="{{ APP.name }}" height="24">
        </a>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Chiudi"></button>
    </div>
    <div class="offcanvas-body">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" href="/rules">
                    <span class="bi bi-ui-checks me-2"></span> Regolamento
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fs-6" href="/storyboard">
                    <span class="bi bi-globe-europe-africa me-2"></span> Ambientazione
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/how-to-play">
                    <span class="bi bi-book me-2"></span> Come giocare
                </a>
            </li>
        </ul>
        <div class="mt-auto pt-3 border-top">
            <button class="btn btn-light w-100" type="button" data-action="open-signin-modal" data-bs-dismiss="offcanvas">
                <span class="bi bi-door-open me-1"></span> Accedi
            </button>
        </div>
    </div>
</aside>
