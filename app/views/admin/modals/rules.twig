<div class="modal fade" id="admin-rules-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-6 text-center mt-3 mb-2">Articolo regolamento</h4>
                <hr class="my-4" />

                <form id="admin-rules-form" class="row g-3">
                    <input type="hidden" name="id" value="">
                    <div class="col-12 col-md-6">
                        <label class="form-label">Articolo <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" name="article" min="1" required>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Sottoarticolo <span class="text-muted small">(0 = principale)</span></label>
                        <input type="number" class="form-control" name="subarticle" min="0" value="0">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Titolo <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="title" maxlength="75" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Contenuto <span class="text-muted small">(HTML supportato)</span></label>
                        <textarea class="form-control" name="body" rows="12" placeholder="Contenuto dell'articolo..."></textarea>
                    </div>
                </form>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="button" class="btn btn-outline-danger d-none" data-action="admin-rules-delete">Elimina</button>
                    <button type="button" class="btn btn-primary" data-action="admin-rules-save">Salva</button>
                </div>
            </div>
        </div>
    </div>
</div>
