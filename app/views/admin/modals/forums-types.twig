<div class="modal fade" id="admin-forum-types-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-6 text-center mt-3 mb-2">Categoria forum</h4>
                <hr class="my-4" />

                <form id="admin-forum-types-form" class="row g-3">
                    <input type="hidden" name="id" value="">
                    <div class="col-12">
                        <label class="form-label">Titolo <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="title" maxlength="75" required>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Visibilità</label>
                        <select class="form-select" name="is_on_game">
                            <option value="0">Off-game</option>
                            <option value="1">In-game</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Sottotitolo <span class="text-muted small">(opzionale)</span></label>
                        <textarea class="form-control" name="subtitle" rows="3" maxlength="500" placeholder="Breve descrizione della categoria..."></textarea>
                    </div>
                </form>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="button" class="btn btn-outline-danger d-none" data-action="admin-forum-types-delete">Elimina</button>
                    <button type="button" class="btn btn-primary" data-action="admin-forum-types-save">Salva</button>
                </div>
            </div>
        </div>
    </div>
</div>
