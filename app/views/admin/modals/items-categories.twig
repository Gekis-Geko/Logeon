<div class="modal fade" id="admin-items-categories-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-6 text-center mt-3 mb-2">Categoria oggetti</h4>
                <hr class="my-4" />

                <form id="admin-items-categories-form" class="row g-3">
                    <input type="hidden" name="id" value="">
                    <div class="col-12">
                        <label class="form-label">Nome <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="name" maxlength="100" required>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Ordine</label>
                        <input type="number" class="form-control" name="sort_order" min="0" value="0">
                    </div>
                    <div class="col-12 col-md-8">
                        <label class="form-label">Icona <span class="text-muted small">(URL, path o classe CSS)</span></label>
                        <div data-img-upload-wrap>
                            <div class="btn-group btn-group-sm mb-2" role="group">
                                <button type="button" class="btn btn-outline-primary active" data-img-tab-btn="link">Incolla link / classe</button>
                                <button type="button" class="btn btn-outline-primary" data-img-tab-btn="upload">Carica file</button>
                            </div>
                            <div data-img-tab-panel="link">
                                <input type="text" class="form-control" name="icon" maxlength="255" placeholder="https://... oppure bi-box">
                            </div>
                            <div data-img-tab-panel="upload" style="display:none">
                                <div class="border rounded p-3 text-center text-muted mb-2" data-upload-drop="item_cat_icon" style="cursor:pointer">
                                    <i class="bi bi-image me-1"></i> Trascina qui l'immagine oppure
                                    <button type="button" class="btn btn-sm btn-outline-primary ms-2" data-upload-target="item_cat_icon">scegli file</button>
                                </div>
                                <div class="form-text">Formati: jpg, png, gif, webp, svg. Max 2 MB.</div>
                                <div class="progress mt-2 d-none" data-upload-progress="item_cat_icon">
                                    <div class="progress-bar" role="progressbar" style="width: 0%;">0%</div>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger mt-2 d-none" data-upload-cancel="item_cat_icon">Annulla</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Descrizione <span class="text-muted small">(opzionale)</span></label>
                        <input type="text" class="form-control" name="description" maxlength="255">
                    </div>
                </form>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="button" class="btn btn-outline-danger d-none" data-action="admin-items-categories-delete">Elimina</button>
                    <button type="button" class="btn btn-primary" data-action="admin-items-categories-save">Salva</button>
                </div>
            </div>
        </div>
    </div>
</div>
