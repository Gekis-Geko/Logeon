<div class="modal fade" id="admin-forums-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-6 text-center mt-3 mb-2">Forum</h4>
                <hr class="my-4" />

                <form id="admin-forums-form" class="row g-3">
                    <input type="hidden" name="id" value="">
                    <div class="col-12">
                        <label class="form-label">Nome <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="name" maxlength="100" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Tipo <span class="text-danger">*</span></label>
                        <select class="form-select" name="type">
                            <option value="">— seleziona tipo —</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Descrizione <span class="text-muted small">(opzionale)</span></label>
                        <textarea class="form-control" name="description" rows="3" maxlength="255" placeholder="Breve descrizione del forum..."></textarea>
                    </div>
                </form>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="button" class="btn btn-outline-danger d-none" data-action="admin-forums-delete">Elimina</button>
                    <button type="button" class="btn btn-primary" data-action="admin-forums-save">Salva</button>
                </div>
            </div>
        </div>
    </div>
</div>
