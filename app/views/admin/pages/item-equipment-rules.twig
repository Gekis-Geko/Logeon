<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Regole equipaggiamento</h4>
        <h6>Associazione oggetti-slot con priorita guidata</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-item-equipment-rules-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-item-equipment-rules-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova regola
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-item-equipment-rules-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-item-equipment-rules-filter-item" class="form-label mb-1">Oggetto</label>
                <select id="admin-item-equipment-rules-filter-item" name="item_id" class="form-select">
                    <option value="">Tutti gli oggetti</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-item-equipment-rules-filter-slot" class="form-label mb-1">Slot equipaggiamento</label>
                <select id="admin-item-equipment-rules-filter-slot" name="slot_id" class="form-select">
                    <option value="">Tutti gli slot</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/item-equipment-rules">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-item-equipment-rules"></div>
{% include 'admin/modals/item-equipment-rules.twig' %}
