<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Categorie oggetti</h4>
        <h6>Gestione categorie e raggruppamenti degli oggetti</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-items-categories-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-items-categories-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova categoria
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-items-categories-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-items-categories-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-items-categories-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Cerca nome...">
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/items-categories">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-items-categories"></div>
{% include 'admin/modals/items-categories.twig' %}
