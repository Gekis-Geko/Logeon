<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Eventi gilde</h4>
        <h6>Gestione eventi e appuntamenti delle gilde</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-guild-events-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-guild-events-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo evento
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-guild-events-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-guild-events-filter-guild" class="form-label mb-1">Gilda</label>
                <select id="admin-guild-events-filter-guild" name="guild_id" class="form-select">
                    <option value="">Tutte</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-guild-events-filter-title" class="form-label mb-1">Titolo</label>
                <input id="admin-guild-events-filter-title" name="title" type="text" class="form-control" maxlength="120" placeholder="Cerca titolo...">
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/guilds-events">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-guild-events"></div>
{% include 'admin/modals/guilds-events.twig' %}
