<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Utenti</h4>
        <h6>Gestione account registrati della piattaforma</h6>
    </header>
</div>
<div class="card card-body mb-3">
    <form id="admin-users-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
        <div class="col-auto">
            <label for="admin-users-filter-search" class="form-label mb-1">
                {{ session('user_is_superuser') == 1 ? 'Ricerca utente (email o personaggio)' : 'Ricerca personaggio' }}
            </label>
            <input id="admin-users-filter-search"
                    name="search"
                    type="text"
                    class="form-control form-control-sm"
                    placeholder="{{ session('user_is_superuser') == 1 ? 'Cerca per email o nome personaggio' : 'Cerca per nome personaggio' }}">
        </div>
        <div class="col-auto">
            <label for="admin-users-filter-status" class="form-label mb-1">Filtro stato</label>
            <select id="admin-users-filter-status" name="status" class="form-select form-select-sm">
                <option value="all">Tutti</option>
                <option value="active">Attivo</option>
                <option value="disabled">Disattivo</option>
                <option value="pending">Da attivare</option>
            </select>
        </div>
        <div class="col-auto">
            <a class="btn btn-sm btn-outline-secondary" href="/admin/users">Reset</a>
        </div>
        <div class="form-text mt-2 px-3">
            Stato utente: attivo = account confermato, disattivo = accesso revocato dopo almeno un login, da attivare = mai attivato.
        </div>
    </form>
</div>

<div id="grid-admin-users"
     data-current-user-id="{{ session('user_id') }}"
     data-current-user-is-admin="{{ session('user_is_administrator') == 1 ? 1 : 0 }}"
     data-current-user-is-superuser="{{ (session('user_is_superuser') == 1 or (session('user_is_superuser') is null and session('user_is_administrator') == 1)) ? 1 : 0 }}"
     data-current-user-is-moderator="{{ session('user_is_moderator') == 1 ? 1 : 0 }}"></div>
