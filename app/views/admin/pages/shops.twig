<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Negozi</h4>
        <h6>Gestione negozi globali e legati ai luoghi di gioco</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-shops-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-shops-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo negozio
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-shops-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-shops-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-shops-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Nome negozio">
            </div>
            <div class="col-auto">
                <label for="admin-shops-filter-type" class="form-label mb-1">Tipo</label>
                <select id="admin-shops-filter-type" name="type" class="form-select">
                    <option value="all" selected>Tutti</option>
                    <option value="global">Globale</option>
                    <option value="location">Luogo</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-shops-filter-status" class="form-label mb-1">Stato</label>
                <select id="admin-shops-filter-status" name="status" class="form-select">
                    <option value="all" selected>Tutti</option>
                    <option value="active">Attivi</option>
                    <option value="inactive">Inattivi</option>
                </select>
            </div>
            <div class="position-relative col-auto">
                <label for="admin-shops-filter-location-label" class="form-label mb-1">Luogo</label>
                <input id="admin-shops-filter-location-label"
                       name="location_label"
                       type="text"
                       class="form-control"
                       maxlength="120"
                       placeholder="Cerca luogo...">
                <input type="hidden" name="location_id" value="">
                <div class="list-group mt-1 d-none" data-role="admin-shops-filter-location-suggestions"></div>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/shops">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-shops"></div>
{% include 'admin/modals/shops.twig' %}
