<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Rarità oggetti</h4>
        <h6>Gestione livelli di rarità assegnabili agli oggetti</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-items-rarities-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-items-rarities-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova rarità
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-items-rarities-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-items-rarities-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-items-rarities-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Cerca nome...">
            </div>
            <div class="col-auto">
                <label for="admin-items-rarities-filter-active" class="form-label mb-1">Stato</label>
                <select id="admin-items-rarities-filter-active" name="is_active" class="form-select">
                    <option value="">Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Disattivi</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/items-rarities">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-items-rarities"></div>
{% include 'admin/modals/items-rarities.twig' %}
