<div data-admin-page="archetypes">
    <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
        <header>
            <h4 class="display-6 mb-1">Archetipi</h4>
            <h6 class="mb-0">Gestisci gli archetipi e la configurazione del sistema</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-archetypes-config-open">
                <i class="bi bi-sliders me-1"></i>Configurazione
            </button>
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-archetypes-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-archetype-create">
                <i class="bi bi-plus-lg me-1"></i>Nuovo archetipo
            </button>
        </div>
    </div>

    {# Filtri #}
    <div class="card card-body mb-3">
        <form id="admin-archetypes-filters" class="d-flex flex-wrap align-items-end gap-2">
            <div>
                <label class="form-label small mb-1">Cerca</label>
                <input type="search" name="search" class="form-control form-control-sm" placeholder="Nome, slug..." style="width:220px;">
            </div>
            <div>
                <label class="form-label small mb-1">Stato</label>
                <select name="is_active" class="form-select form-select-sm" style="width:130px;">
                    <option value="">Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Inattivi</option>
                </select>
            </div>
            <div>
                <label class="form-label small mb-1">Selezionabile</label>
                <select name="is_selectable" class="form-select form-select-sm" style="width:150px;">
                    <option value="">Tutti</option>
                    <option value="1">Sì</option>
                    <option value="0">No</option>
                </select>
            </div>
            <div class="d-flex gap-2 mt-3">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/archetypes">Reset</a>
            </div>
        </form>
    </div>

    <div id="grid-admin-archetypes"></div>

    {% include 'admin/modals/archetypes.twig' %}
    {% include 'admin/modals/archetypes-config.twig' %}
</div>
