<div data-admin-page="logs-job">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Logs Lavori</h4>
            <h6>Storico completamento task e guadagni dai lavori</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-logs-job-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-logs-job-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-logs-job-filter-character-id" class="form-label mb-1">ID Personaggio</label>
                    <input id="admin-logs-job-filter-character-id" name="character_id" type="number" class="form-control" min="1" placeholder="ID personaggio">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-job-filter-job-id" class="form-label mb-1">ID Lavoro</label>
                    <input id="admin-logs-job-filter-job-id" name="job_id" type="number" class="form-control" min="1" placeholder="ID lavoro">
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/logs-job">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-logs-job"></div>
</div>
