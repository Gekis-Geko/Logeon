<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Regolamento</h4>
        <h6>Gestione articoli e regole di gioco</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-rules-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-rules-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo articolo
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-rules-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-rules-filter-title" class="form-label mb-1">Titolo</label>
                <input id="admin-rules-filter-title" name="title" type="text" class="form-control" maxlength="75" placeholder="Cerca titolo...">
            </div>
            <div class="col-auto">
                <label for="admin-rules-filter-article" class="form-label mb-1">Articolo</label>
                <input id="admin-rules-filter-article" name="article" type="number" class="form-control" min="1" placeholder="N. articolo...">
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/rules">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-rules"></div>
{% include 'admin/modals/rules.twig' %}
