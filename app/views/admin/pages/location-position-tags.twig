<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 mt-3">
    <header>
        <h4 class="display-6 mb-1">Tag di posizione</h4>
        <h6 class="mb-0">Suggerimenti narrativi di posizione per le location (panchina, tavolo, ingresso...).</h6>
    </header>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-location-position-tags-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo tag
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-location-position-tags-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>
</div>

<div class="card card-body mb-3">
    <form id="admin-location-position-tags-filters" class="row g-2 align-items-end">
        <div class="col-auto">
            <label for="admin-lpt-search" class="form-label mb-1">Cerca nome</label>
            <input type="text" id="admin-lpt-search" name="search" class="form-control form-control-sm" placeholder="Cerca..." autocomplete="off">
        </div>
        <div class="col-auto" style="min-width:200px;">
            <label for="admin-lpt-location-label" class="form-label mb-1">Location</label>
            <input type="hidden" name="location_id" value="">
            <input type="text" id="admin-lpt-location-label" name="location_label" class="form-control form-control-sm" placeholder="Filtra per location..." autocomplete="off">
            <div class="list-group mt-1 d-none position-absolute" style="z-index:1000;min-width:220px;" data-role="admin-lpt-filter-location-suggestions"></div>
        </div>
        <div class="col-auto">
            <label for="admin-lpt-filter-active" class="form-label mb-1">Stato</label>
            <select id="admin-lpt-filter-active" name="is_active" class="form-select form-select-sm">
                <option value="">Tutti</option>
                <option value="1">Attivi</option>
                <option value="0">Inattivi</option>
            </select>
        </div>
        <div class="col-auto d-flex gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="/admin/location-position-tags">Reset</a>
        </div>
    </form>
</div>

<div id="grid-admin-location-position-tags"></div>

{% include 'admin/modals/location-position-tags.twig' %}
