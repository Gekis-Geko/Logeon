<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 mt-3">
    <header>
        <h4 class="display-6 mb-1">Meteo e Clima - Profili</h4>
        <h6 class="mb-0">Profili stagionali, pesi meteo e assegnazioni climatiche.</h6>
    </header>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/admin/weather-overview" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Panoramica
        </a>
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-weather-reload-all">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <div>
            <h5 class="mb-0">Profili stagionali e pesi meteo</h5>
            <p class="text-muted small mb-0">Ogni profilo lega una zona climatica a una stagione con intervallo di temperatura e distribuzione meteo.</p>
        </div>
        <div class="d-flex gap-1">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-weather-profiles-reload"><i class="bi bi-arrow-clockwise me-1"></i></button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-weather-profiles-create"><i class="bi bi-plus-lg me-1"></i></button>
        </div>
    </div>
    <div class="card-body">
        <form class="row g-2 align-items-end mb-3" data-role="admin-weather-profiles-filters" autocomplete="off" novalidate>
            <div class="col-auto">
                <label class="form-label mb-1" for="admin-weather-profiles-filter-query">Ricerca</label>
                <input id="admin-weather-profiles-filter-query" type="search" class="form-control form-control-sm" data-role="admin-weather-profiles-filter-query" data-weather-filter-target="weather-profiles" placeholder="Zona, stagione, meteo predefinito..." />
            </div>
            <div class="col-auto">
                <label class="form-label mb-1" for="admin-weather-profiles-filter-state">Stato</label>
                <select id="admin-weather-profiles-filter-state" class="form-select form-select-sm" data-role="admin-weather-profiles-filter-state" data-weather-filter-target="weather-profiles">
                    <option value="all" selected>Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Inattivi</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-weather-profiles-reset-filters">Reset</button>
            </div>
        </form>
        <div id="grid-admin-weather-profiles"></div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <div>
            <h5 class="mb-0">Assegnazioni climatiche</h5>
            <p class="text-muted small mb-0">Associa una zona climatica a mondo, mappa, luogo, regione o area.</p>
        </div>
        <div class="d-flex gap-1">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-weather-assignments-reload"><i class="bi bi-arrow-clockwise"></i></button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-weather-assignments-create"><i class="bi bi-plus-lg"></i></button>
        </div>
    </div>
    <div class="card-body">
        <form class="row g-2 align-items-end mb-3" data-role="admin-weather-assignments-filters" autocomplete="off" novalidate>
            <div class="col-auto">
                <label class="form-label mb-1" for="admin-weather-assignments-filter-query">Ricerca</label>
                <input id="admin-weather-assignments-filter-query" type="search" class="form-control form-control-sm" data-role="admin-weather-assignments-filter-query" data-weather-filter-target="weather-assignments" placeholder="Ambito, riferimento, zona..." />
            </div>
            <div class="col-auto">
                <label class="form-label mb-1" for="admin-weather-assignments-filter-scope">Ambito</label>
                <select id="admin-weather-assignments-filter-scope" class="form-select form-select-sm" data-role="admin-weather-assignments-filter-scope" data-weather-filter-target="weather-assignments">
                    <option value="" selected>Tutti</option>
                    <option value="world">Mondo</option>
                    <option value="map">Mappa</option>
                    <option value="location">Luogo</option>
                    <option value="region">Regione</option>
                    <option value="area">Area</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label mb-1" for="admin-weather-assignments-filter-state">Stato</label>
                <select id="admin-weather-assignments-filter-state" class="form-select form-select-sm" data-role="admin-weather-assignments-filter-state" data-weather-filter-target="weather-assignments">
                    <option value="all" selected>Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Inattivi</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-weather-assignments-reset-filters">Reset</button>
            </div>
        </form>
        <div id="grid-admin-weather-assignments"></div>
    </div>
</div>

{% include 'admin/modals/weather.twig' %}
