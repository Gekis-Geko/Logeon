<div data-admin-page="logs-narrative">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Log Narrativi</h4>
            <h6>Storico azioni di delega narrativa registrate dal sistema</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-logs-narrative-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-logs-narrative-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-logs-narrative-filter-action" class="form-label mb-1">Azione</label>
                    <input id="admin-logs-narrative-filter-action" name="action" type="text" class="form-control" placeholder="Azione">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-narrative-filter-author" class="form-label mb-1">Autore (ID utente)</label>
                    <input id="admin-logs-narrative-filter-author" name="author" type="number" class="form-control" min="1" placeholder="ID utente">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-narrative-filter-date-from" class="form-label mb-1">Dal</label>
                    <input id="admin-logs-narrative-filter-date-from" name="date_from" type="date" class="form-control">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-narrative-filter-date-to" class="form-label mb-1">Al</label>
                    <input id="admin-logs-narrative-filter-date-to" name="date_to" type="date" class="form-control">
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/logs-narrative">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-logs-narrative"
         data-current-user-is-superuser="{{ (session('user_is_superuser') == 1 or (session('user_is_superuser') is null and session('user_is_administrator') == 1)) ? 1 : 0 }}"></div>
</div>
