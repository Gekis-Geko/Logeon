<div data-admin-page="locations">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Luoghi</h4>
            <h6>Gestione luoghi di gioco e relative proprietà</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-locations-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-locations-create">
                <i class="bi bi-plus-lg me-1"></i>Nuovo luogo
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-locations-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-locations-filter-name" class="form-label mb-1">Nome</label>
                    <input id="admin-locations-filter-name" name="name" type="text" class="form-control" maxlength="120" placeholder="Nome luogo">
                </div>
                <div class="position-relative col-auto">
                    <label for="admin-locations-filter-map-label" class="form-label mb-1">Mappa</label>
                    <input id="admin-locations-filter-map-label"
                           name="map_label"
                           type="text"
                           class="form-control"
                           maxlength="120"
                           placeholder="Cerca mappa...">
                    <input type="hidden" name="map_id" value="">
                    <div class="list-group mt-1 position-absolute w-100" style="z-index:100;display:none" data-role="admin-locations-filter-map-suggestions"></div>
                </div>
                <div class="col-auto">
                    <label for="admin-locations-filter-status" class="form-label mb-1">Stato</label>
                    <select id="admin-locations-filter-status" name="status" class="form-select">
                        <option value="" selected>Tutti</option>
                        <option value="open">Aperto</option>
                        <option value="closed">Chiuso</option>
                        <option value="locked">Bloccato</option>
                        <option value="private">Privato</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label for="admin-locations-filter-is-house" class="form-label mb-1">Casa</label>
                    <select id="admin-locations-filter-is-house" name="is_house" class="form-select">
                        <option value="" selected>Tutti</option>
                        <option value="1">Si</option>
                        <option value="0">No</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label for="admin-locations-filter-is-chat" class="form-label mb-1">Chat</label>
                    <select id="admin-locations-filter-is-chat" name="is_chat" class="form-select">
                        <option value="" selected>Tutti</option>
                        <option value="1">Si</option>
                        <option value="0">No</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label for="admin-locations-filter-access-policy" class="form-label mb-1">Accesso</label>
                    <select id="admin-locations-filter-access-policy" name="access_policy" class="form-select">
                        <option value="" selected>Tutti</option>
                        <option value="open">Aperta</option>
                        <option value="guild">Solo gilda</option>
                        <option value="invite">Solo invitati</option>
                        <option value="owner">Solo proprietario</option>
                    </select>
                </div>
                <div class="col-auto d-flex align-items-end">
                    <button type="button" class="btn btn-outline-secondary" data-action="admin-locations-filters-reset">
                        <i class="bi bi-x-circle me-1"></i>Reset
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-locations"></div>

    {% include 'admin/modals/locations.twig' %}
</div>
