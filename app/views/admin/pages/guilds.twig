<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Gilde</h4>
        <h6>Gestione gilde e relativi ruoli</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-guilds-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-guilds-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova gilda
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-guilds-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-guilds-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-guilds-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Nome gilda">
            </div>
            <div class="col-auto">
                <label for="admin-guilds-filter-alignment" class="form-label mb-1">Allineamento</label>
                <select id="admin-guilds-filter-alignment" name="alignment_id" class="form-select">
                    <option value="">Tutti</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-guilds-filter-visible" class="form-label mb-1">Visibile</label>
                <select id="admin-guilds-filter-visible" name="is_visible" class="form-select">
                    <option value="">Tutti</option>
                    <option value="1">Sì</option>
                    <option value="0">No</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/guilds">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-guilds"></div>
{% include 'admin/modals/guilds.twig' %}
