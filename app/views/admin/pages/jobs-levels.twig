<div data-admin-page="jobs-levels">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Livelli dei lavori</h4>
            <h6>Gestione livelli di progressione e bonus paga per ogni lavoro</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-jobs-levels-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-jobs-levels-create">
                <i class="bi bi-plus-lg me-1"></i>Nuovo livello
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-jobs-levels-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-jobs-levels-filter-job-id" class="form-label mb-1">Lavoro</label>
                    <select id="admin-jobs-levels-filter-job-id" name="job_id" class="form-select">
                        <option value="">Tutti</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label for="admin-jobs-levels-filter-title" class="form-label mb-1">Titolo livello</label>
                    <input id="admin-jobs-levels-filter-title" name="title" type="text" class="form-control" maxlength="100" placeholder="Titolo livello">
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/jobs-levels">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-jobs-levels"></div>

    {% include 'admin/modals/jobs-levels.twig' %}
</div>
