<div data-admin-page="factions">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 mt-3">
        <header>
            <h4 class="display-6 mb-1">Fazioni</h4>
            <h6 class="mb-0">Organizzazioni narrative macro-livello con membership, relazioni e peso politico nella storia.</h6>
        </header>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-factions-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-faction-create">
                <i class="bi bi-plus-lg me-1"></i>Nuova fazione
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end mb-3">
                <div class="col-auto">
                    <label class="form-label mb-1" for="admin-factions-filter-search">Ricerca</label>
                    <input type="search" class="form-control form-control-sm" id="admin-factions-filter-search" placeholder="Codice, nome...">
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1" for="admin-factions-filter-type">Tipo</label>
                    <select id="admin-factions-filter-type" class="form-select form-select-sm">
                        <option value="">Tutti</option>
                        <option value="political">Politica</option>
                        <option value="military">Militare</option>
                        <option value="religious">Religiosa</option>
                        <option value="criminal">Criminale</option>
                        <option value="mercantile">Mercantile</option>
                        <option value="other">Altra</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1" for="admin-factions-filter-scope">Portata</label>
                    <select id="admin-factions-filter-scope" class="form-select form-select-sm">
                        <option value="">Tutte</option>
                        <option value="local">Locale</option>
                        <option value="regional">Regionale</option>
                        <option value="global">Globale</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1" for="admin-factions-filter-is-active">Stato</label>
                    <select id="admin-factions-filter-is-active" class="form-select form-select-sm">
                        <option value="">Tutti</option>
                        <option value="1">Attive</option>
                        <option value="0">Disattive</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1" for="admin-factions-filter-is-public">Visibilita</label>
                    <select id="admin-factions-filter-is-public" class="form-select form-select-sm">
                        <option value="">Tutte</option>
                        <option value="1">Pubbliche</option>
                        <option value="0">Solo staff</option>
                    </select>
                </div>
                <div class="col-auto d-flex align-items-end">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-factions-filters-reset">Reset</button>
                </div>
            </div>

            <div id="grid-admin-factions"></div>
        </div>
    </div>

    {% include 'admin/modals/factions.twig' %}
</div>
