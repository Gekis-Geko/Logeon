<div data-admin-page="logs-guild">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Logs Gilde</h4>
            <h6>Storico azioni interne alle gilde</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-logs-guild-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-logs-guild-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-logs-guild-filter-guild-id" class="form-label mb-1">ID Gilda</label>
                    <input id="admin-logs-guild-filter-guild-id" name="guild_id" type="number" class="form-control" min="1" placeholder="ID gilda">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-guild-filter-action" class="form-label mb-1">Azione</label>
                    <input id="admin-logs-guild-filter-action" name="action" type="text" class="form-control" placeholder="Azione">
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/logs-guild">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-logs-guild"></div>
</div>
