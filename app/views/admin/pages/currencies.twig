<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Valute</h4>
        <h6>Gestione codici, simboli e disponibilita delle valute di gioco</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-currencies-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-currencies-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova valuta
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-currencies-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-currencies-filter-code" class="form-label mb-1">Codice</label>
                <input id="admin-currencies-filter-code" type="text" class="form-control" name="code" maxlength="20" placeholder="Es. GOLD">
            </div>
            <div class="col-auto">
                <label for="admin-currencies-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-currencies-filter-name" type="text" class="form-control" name="name" maxlength="100" placeholder="Es. Monete d'oro">
            </div>
            <div class="col-auto">
                <label for="admin-currencies-filter-status" class="form-label mb-1">Stato</label>
                <select id="admin-currencies-filter-status" class="form-select" name="status">
                    <option value="all" selected>Tutte</option>
                    <option value="active">Attive</option>
                    <option value="inactive">Inattive</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-currencies-filter-default" class="form-label mb-1">Default</label>
                <select id="admin-currencies-filter-default" class="form-select" name="is_default">
                    <option value="all" selected>Tutte</option>
                    <option value="yes">Solo default</option>
                    <option value="no">No default</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/currencies">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-currencies"></div>
{% include 'admin/modals/currencies.twig' %}
