<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Luoghi delle gilde</h4>
        <h6>Associazione ruoli gilda ai luoghi di gioco</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-guild-locations-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-guild-locations-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova associazione
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-guild-locations-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-guild-locations-filter-guild" class="form-label mb-1">Gilda</label>
                <select id="admin-guild-locations-filter-guild" name="guild_id" class="form-select">
                    <option value="">Tutte</option>
                </select>
            </div>
            <div class="position-relative col-auto">
                <label for="admin-guild-locations-filter-location-label" class="form-label mb-1">Luogo</label>
                <input id="admin-guild-locations-filter-location-label"
                       name="location_label"
                       type="text"
                       class="form-control"
                       maxlength="120"
                       placeholder="Cerca luogo...">
                <input type="hidden" name="location_id" value="">
                <div class="list-group mt-1 d-none" data-role="admin-guild-locations-filter-location-suggestions"></div>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/guilds-locations">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-guild-locations"></div>
{% include 'admin/modals/guilds-locations.twig' %}
