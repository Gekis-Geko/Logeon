<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Inventario Negozi</h4>
        <h6>Gestione degli oggetti disponibili per l'acquisto nei negozi</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-shop-inventory-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-shop-inventory-create">
            <i class="bi bi-plus-lg me-1"></i>Aggiungi voce
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-shop-inventory-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="position-relative col-auto">
                <label for="admin-shop-inventory-filter-shop-label" class="form-label mb-1">Negozio</label>
                <input id="admin-shop-inventory-filter-shop-label"
                       name="shop_label"
                       type="text"
                       class="form-control"
                       maxlength="120"
                       autocomplete="off"
                       placeholder="Cerca negozio...">
                <input type="hidden" name="shop_id" value="">
                <div class="list-group mt-1 d-none" data-role="admin-shop-inventory-filter-shop-suggestions"></div>
            </div>
            <div class="col-auto">
                <label for="admin-shop-inventory-filter-item" class="form-label mb-1">Oggetto</label>
                <input id="admin-shop-inventory-filter-item" name="item_name" type="text" class="form-control" maxlength="100" placeholder="Nome oggetto...">
            </div>
            <div class="col-auto">
                <label for="admin-shop-inventory-filter-status" class="form-label mb-1">Stato</label>
                <select id="admin-shop-inventory-filter-status" name="is_active" class="form-select">
                    <option value="" selected>Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Inattivi</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-shop-inventory-filter-promo" class="form-label mb-1">Promo</label>
                <select id="admin-shop-inventory-filter-promo" name="is_promo" class="form-select">
                    <option value="" selected>Tutti</option>
                    <option value="1">In promo</option>
                    <option value="0">Standard</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/inventory-shop">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-shop-inventory"></div>
{% include 'admin/modals/shop-inventory.twig' %}
