<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Oggetti</h4>
        <h6>Gestione oggetti, equipaggiamento e consumabili</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-items-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-items-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo oggetto
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-items-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-items-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-items-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Cerca nome...">
            </div>
            <div class="col-auto">
                <label for="admin-items-filter-category" class="form-label mb-1">Categoria</label>
                <select id="admin-items-filter-category" name="category_id" class="form-select">
                    <option value="">Tutte</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-items-filter-rarity" class="form-label mb-1">Rarità</label>
                <select id="admin-items-filter-rarity" name="rarity_id" class="form-select">
                    <option value="">Tutte</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/items">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-items"></div>
{% include 'admin/modals/items.twig' %}
