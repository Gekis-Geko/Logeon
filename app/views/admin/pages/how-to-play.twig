<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Come giocare</h4>
        <h6>Gestione passi e guide per iniziare a giocare</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-how-to-play-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-how-to-play-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo passo
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-how-to-play-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-how-to-play-filter-title" class="form-label mb-1">Titolo</label>
                <input id="admin-how-to-play-filter-title" name="title" type="text" class="form-control" maxlength="255" placeholder="Cerca titolo...">
            </div>
            <div class="col-auto">
                <label for="admin-how-to-play-filter-step" class="form-label mb-1">Passo</label>
                <input id="admin-how-to-play-filter-step" name="step" type="number" class="form-control" min="1" placeholder="N. passo...">
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/how-to-play">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-how-to-play"></div>
{% include 'admin/modals/how-to-play.twig' %}
