<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Ambientazione</h4>
        <h6>Gestione capitoli e sottocapitoli dell'ambientazione</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-storyboards-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-storyboards-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo capitolo
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-storyboards-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-storyboards-filter-title" class="form-label mb-1">Titolo</label>
                <input id="admin-storyboards-filter-title" name="title" type="text" class="form-control" maxlength="30" placeholder="Cerca titolo...">
            </div>
            <div class="col-auto">
                <label for="admin-storyboards-filter-chapter" class="form-label mb-1">Capitolo</label>
                <input id="admin-storyboards-filter-chapter" name="chapter" type="number" class="form-control" min="1" placeholder="N. capitolo...">
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/storyboards">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-storyboards"></div>
{% include 'admin/modals/storyboards.twig' %}
