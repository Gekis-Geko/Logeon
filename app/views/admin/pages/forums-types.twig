<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Categorie forum</h4>
        <h6>Gestione tipologie e categorie dei forum</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-forum-types-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-forum-types-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova categoria
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-forum-types-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-forum-types-filter-title" class="form-label mb-1">Titolo</label>
                <input id="admin-forum-types-filter-title" name="title" type="text" class="form-control" maxlength="75" placeholder="Cerca titolo...">
            </div>
            <div class="col-auto">
                <label for="admin-forum-types-filter-on-game" class="form-label mb-1">Visibilità</label>
                <select id="admin-forum-types-filter-on-game" name="is_on_game" class="form-select">
                    <option value="">Tutti</option>
                    <option value="1">In-game</option>
                    <option value="0">Off-game</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/forums-types">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-forum-types"></div>
{% include 'admin/modals/forums-types.twig' %}
