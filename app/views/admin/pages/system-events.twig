<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6 mb-1">Eventi di sistema</h4>
        <h6 class="mb-0">Gestione operativa eventi automatici: pianificazione, partecipazioni e ricompense.</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-system-events-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-system-events-maintenance">
            <i class="bi bi-cpu me-1"></i>Manutenzione
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-system-events-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo evento
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-system-events-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-system-events-filter-status" class="form-label mb-1">Stato</label>
                <select id="admin-system-events-filter-status" class="form-select form-select-sm">
                    <option value="">Tutti gli stati</option>
                    <option value="draft">Bozza</option>
                    <option value="scheduled">Programmato</option>
                    <option value="active">Attivo</option>
                    <option value="completed">Completato</option>
                    <option value="cancelled">Annullato</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-system-events-filter-mode" class="form-label mb-1">Partecipanti</label>
                <select id="admin-system-events-filter-mode" class="form-select form-select-sm">
                    <option value="">Tutte le modalita</option>
                    <option value="character">Personaggi</option>
                    <option value="faction">Fazioni</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-system-events-filter-tag" class="form-label mb-1">Tag</label>
                <select id="admin-system-events-filter-tag" class="form-select form-select-sm">
                    <option value="">Tutti i tag</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-system-events-filters-reset">Reset</button>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-system-events"></div>

{% include 'admin/modals/system-events.twig' %}

