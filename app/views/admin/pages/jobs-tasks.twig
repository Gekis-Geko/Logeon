<div data-admin-page="jobs-tasks">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Compiti dei lavori</h4>
            <h6>Gestione compiti assegnabili ai personaggi per ogni lavoro</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-jobs-tasks-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-jobs-tasks-create">
                <i class="bi bi-plus-lg me-1"></i>Nuovo compito
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-jobs-tasks-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-jobs-tasks-filter-title" class="form-label mb-1">Titolo</label>
                    <input id="admin-jobs-tasks-filter-title" name="title" type="text" class="form-control" maxlength="150" placeholder="Titolo compito">
                </div>
                <div class="col-auto">
                    <label for="admin-jobs-tasks-filter-job-label" class="form-label mb-1">Lavoro</label>
                    <select id="admin-jobs-tasks-filter-job-id" name="job_id" class="form-select">
                        <option value="">Tutti</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label for="admin-jobs-tasks-filter-is-active" class="form-label mb-1">Stato</label>
                    <select id="admin-jobs-tasks-filter-is-active" name="is_active" class="form-select">
                        <option value="" selected>Tutti</option>
                        <option value="1">Attivi</option>
                        <option value="0">Inattivi</option>
                    </select>
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/jobs-tasks">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-jobs-tasks"></div>

    {% include 'admin/modals/jobs-tasks.twig' %}
</div>
