<div data-admin-page="logs-conflicts">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Logs Conflitti</h4>
            <h6>Storico dei tiri di dado nei conflitti</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-logs-conflicts-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-logs-conflicts-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-logs-conflicts-filter-conflict-id" class="form-label mb-1">ID Conflitto</label>
                    <input id="admin-logs-conflicts-filter-conflict-id" name="conflict_id" type="number" class="form-control" min="1" placeholder="ID conflitto">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-conflicts-filter-roll-type" class="form-label mb-1">Tipo tiro</label>
                    <input id="admin-logs-conflicts-filter-roll-type" name="roll_type" type="text" class="form-control" placeholder="Tipo tiro">
                </div>
                <div class="col-auto">
                    <label for="admin-logs-conflicts-filter-die-used" class="form-label mb-1">Dado usato</label>
                    <input id="admin-logs-conflicts-filter-die-used" name="die_used" type="text" class="form-control" placeholder="Es. d20">
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/logs-conflicts">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-logs-conflicts"></div>
</div>
