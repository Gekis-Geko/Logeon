<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Allineamenti gilde</h4>
        <h6>Gestione allineamenti disponibili per le gilde</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-guild-alignments-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-guild-alignments-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo allineamento
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-guild-alignments-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-guild-alignments-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-guild-alignments-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Nome allineamento">
            </div>
            <div class="col-auto">
                <label for="admin-guild-alignments-filter-status" class="form-label mb-1">Stato</label>
                <select id="admin-guild-alignments-filter-status" name="is_active" class="form-select">
                    <option value="">Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Inattivi</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/guild-alignments">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-guild-alignments"></div>
{% include 'admin/modals/guild-alignments.twig' %}
