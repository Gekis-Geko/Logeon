<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6">Slot equipaggiamento</h4>
        <h6>Gestione slot disponibili per il sistema di equipaggiamento</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-equipment-slots-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-equipment-slots-create">
            <i class="bi bi-plus-lg me-1"></i>Nuovo slot
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-equipment-slots-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-equipment-slots-filter-key" class="form-label mb-1">Chiave slot</label>
                <select id="admin-equipment-slots-filter-key" name="key" class="form-select">
                    <option value="">Tutte le chiavi</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-equipment-slots-filter-name" class="form-label mb-1">Nome</label>
                <input id="admin-equipment-slots-filter-name" name="name" type="text" class="form-control" maxlength="100" placeholder="Es. Mano principale">
            </div>
            <div class="col-auto">
                <label for="admin-equipment-slots-filter-active" class="form-label mb-1">Stato</label>
                <select id="admin-equipment-slots-filter-active" name="is_active" class="form-select">
                    <option value="">Tutti</option>
                    <option value="1">Attivi</option>
                    <option value="0">Inattivi</option>
                </select>
            </div>
            <div class="d-flex gap-2 col-auto">
                <a class="btn btn-sm btn-outline-secondary" href="/admin/equipment-slots">Reset</a>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-equipment-slots"></div>
{% include 'admin/modals/equipment-slots.twig' %}
