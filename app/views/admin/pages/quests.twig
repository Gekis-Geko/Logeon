<div class="d-flex justify-content-between align-items-center mb-3">
    <header class="mt-3">
        <h4 class="display-6 mb-1">Quest</h4>
        <h6 class="mb-0">Gestione definizioni, progressione e istanze operative.</h6>
    </header>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-quests-reload">
            <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-quests-maintenance">
            <i class="bi bi-cpu me-1"></i>Manutenzione
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-action="admin-quest-create">
            <i class="bi bi-plus-lg me-1"></i>Nuova quest
        </button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form id="admin-quests-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
            <div class="col-auto">
                <label for="admin-quests-filter-status" class="form-label mb-1">Stato</label>
                <select id="admin-quests-filter-status" class="form-select form-select-sm">
                    <option value="">Tutti gli stati</option>
                    <option value="draft">Bozza</option>
                    <option value="published">Pubblicata</option>
                    <option value="archived">Archiviata</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-quests-filter-scope" class="form-label mb-1">Ambito</label>
                <select id="admin-quests-filter-scope" class="form-select form-select-sm">
                    <option value="">Tutti gli ambiti</option>
                    <option value="world">Mondo</option>
                    <option value="character">Personaggio</option>
                    <option value="faction">Fazione</option>
                    <option value="guild">Gilda</option>
                    <option value="map">Mappa</option>
                    <option value="location">Luogo</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-quests-filter-tag" class="form-label mb-1">Tag</label>
                <select id="admin-quests-filter-tag" class="form-select form-select-sm">
                    <option value="">Tutti i tag</option>
                </select>
            </div>
            <div class="col-auto">
                <label for="admin-quests-filter-search" class="form-label mb-1">Ricerca</label>
                <input id="admin-quests-filter-search" type="search" class="form-control form-control-sm" placeholder="Cerca quest...">
            </div>
            <div class="d-flex gap-2 col-auto">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="admin-quests-filters-reset">Reset</button>
            </div>
        </form>
    </div>
</div>

<div id="grid-admin-quests"></div>

{% include 'admin/modals/quests.twig' %}

