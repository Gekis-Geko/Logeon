<div class="modal fade" id="signup-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-5 text-center mt-3 mb-3">Iscriviti gratis</h4>
                <h6 class="text-center text-muted">Crea il tuo account: riceverai un link email per attivarlo.</h6>

                <hr class="my-4" />

                <div class="d-grid gap-2 col-10 mx-auto my-4">
                    <form id="signup-modal-form">
                        <div class="form-floating my-3">
                            <input type="email" name="email" class="form-control" placeholder="Inserisci la tua email" autocomplete="email" required>
                            <label>Inserisci la tua email</label>
                        </div>
                        <div class="form-floating my-4">
                            <input type="password" name="password" class="form-control" placeholder="Inserisci la tua password" minlength="10" maxlength="72" autocomplete="new-password" required>
                            <label>Inserisci la tua password</label>
                        </div>
                        <div class="form-floating my-4">
                            <input type="password" name="password_confirm" class="form-control" placeholder="Conferma la tua password" minlength="10" maxlength="72" autocomplete="new-password" required>
                            <label>Conferma la tua password</label>
                        </div>
                        <div class="small text-muted">
                            La password deve contenere almeno 10 caratteri, una maiuscola, una minuscola, un numero e un simbolo.
                        </div>

                        <div class="d-grid gap-2 col-6 mx-auto my-5">
                            <button type="submit" class="btn btn-lg btn-primary btn-block btn-round">ISCRIVITI</button>
                        </div>
                    </form>

                    <button type="button" class="btn btn-sm btn-link" data-action="signup-modal-back"><span class="bi bi-arrow-left"></span> indietro</button>
                </div>

            </div>
        </div>
    </div>
</div>
