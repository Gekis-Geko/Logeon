{% set googleAuth = google_auth|default({}) %}
{% set googleAuthEnabled = googleAuth.enabled|default(false) %}
<div class="modal fade" id="signin-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-5 text-center mt-3 mb-3">ACCEDI</h4>
                <h6 class="text-center text-muted">Entra nella piattaforma per scoprire tutte le funzionalita</h6>

                <hr class="my-4" />

                <div class="d-grid gap-2 col-10 mx-auto my-4">
                    <form id="signin-modal-form">
                        <div class="form-floating my-3">
                            <input type="email" name="email" class="form-control" placeholder="Il tuo indirizzo email">
                            <label>Il tuo indirizzo email</label>
                        </div>
                        <div class="form-floating my-4">
                            <input type="password" name="password" class="form-control" placeholder="La tua password">
                            <label>La tua password</label>
                            <small><a href="#" data-action="open-forgot-password-modal">Hai dimenticato la password?</a></small>
                        </div>
                        <div class="d-grid gap-2 col-6 mx-auto my-5">
                            <button type="submit" class="btn btn-lg btn-primary btn-block btn-round">ACCEDI</button>
                        </div>
                        {% if googleAuthEnabled %}
                            <div class="d-grid gap-2 col-10 mx-auto mb-4">
                                <a href="/auth/google/start?mode=signin" class="btn btn-outline-danger btn-round">
                                    <i class="bi bi-google me-2"></i>Continua con Google
                                </a>
                            </div>
                        {% endif %}
                    </form>

                    <hr />

                    <p class="text-center text-muted">
                        Non sei ancora iscritto? Iscriviti subito gratis
                    </p>

                    <div class="d-flex justify-content-evenly col-8 mx-auto">
                        <button type="button" class="btn btn-lg btn-secondary btn-block btn-round" data-action="open-signup-modal">ISCRIVITI</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>