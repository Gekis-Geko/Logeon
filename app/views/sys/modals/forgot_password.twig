<div class="modal fade" id="forgot-password-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <div class="d-flex justify-content-end my-3 mx-4">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <h4 class="display-6 text-center mt-3 mb-3">Recupera la password</h4>
                <h6 class="text-center text-muted">Inserisci la tua email: se risulta registrata riceverai un link di recupero.</h6>

                <hr class="my-4" />

                <div class="d-grid gap-2 col-10 mx-auto my-4">
                    <form id="forgot-password-modal-form">
                        <div class="form-floating my-3">
                            <input type="email" name="email" class="form-control" placeholder="Il tuo indirizzo email" autocomplete="email" required>
                            <label>Il tuo indirizzo email</label>
                        </div>
                        <div class="d-grid gap-2 col-6 mx-auto my-5">
                            <button type="submit" class="btn btn-lg btn-primary btn-block btn-round">RECUPERA</button>
                        </div>
                    </form>

                    <button type="button" class="btn btn-sm btn-link" data-action="forgot-password-modal-back"><span class="bi bi-arrow-left"></span> indietro</button>
                </div>

            </div>
        </div>
    </div>
</div>
