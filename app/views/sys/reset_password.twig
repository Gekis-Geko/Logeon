{% extends theme_shell('public', 'layouts/layout.twig') %}

{% block content %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="mb-3">Reimposta password</h4>
                    <p class="text-muted">Inserisci una nuova password sicura per il tuo account.</p>

                    <form id="reset-password-form">
                        <input type="hidden" name="token" value="{{ token }}">
                        <div class="form-floating my-3">
                            <input type="password" name="password" class="form-control" placeholder="Nuova password" minlength="10" maxlength="72" autocomplete="new-password" required>
                            <label>Nuova password</label>
                        </div>
                        <div class="form-floating my-3">
                            <input type="password" name="rewrite_password" class="form-control" placeholder="Conferma password" minlength="10" maxlength="72" autocomplete="new-password" required>
                            <label>Conferma password</label>
                        </div>
                        <div class="small text-muted text-center">
                            Usa almeno 10 caratteri con maiuscola, minuscola, numero e simbolo.
                        </div>
                        <div class="d-grid gap-2 col-6 mx-auto my-4">
                            <button type="submit" class="btn btn-lg btn-primary btn-block btn-round">Conferma</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

