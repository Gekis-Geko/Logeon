        }
      ]
    },
    "game": {
      "info_dropdown": [
        {
          "label": "Archetipi",
          "href": "/game/archetypes",
          "icon": "bi bi-person-badge",
          "order": 220
        }
      ],
      "info_offcanvas": [
        {
          "label": "Archetipi",
          "href": "/game/archetypes",
          "icon": "bi bi-person-badge",
          "order": 220
        }
      ]
    },
    "admin": {
      "aside": [
        {
          "label": "Archetipi",
          "href": "/admin/archetypes",
          "icon": "bi bi-person-badge",
          "page": "archetypes",
          "section": "Parametri ed entita",
          "section_order": 20,
          "order": 120
        }
      ]
    }
  },
  "features": [
    "character.archetype.provider.override"
  ],
  "assets": {
    "admin": {
      "js": ["dist/admin.js"]
