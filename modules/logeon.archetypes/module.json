{
  "id": "logeon.archetypes",
  "name": "Logeon Archetypes",
  "version": "0.1.0",
  "vendor": "Logeon",
  "description": "Modulo Archetipi: provider runtime agganciato via hook character.archetype.provider.",
  "category": "gameplay",
  "class": "bundled",
  "compat": {
    "min": "0.8.0",
    "max": ""
  },
  "requires": [],
  "entrypoints": {
    "bootstrap": "bootstrap.php",
    "routes": "routes.php"
  },
  "menus": {
    "public": {
      "navbar": [
        {
          "label": "Archetipi",
          "href": "/archetypes",
          "icon": "bi bi-person-badge",
