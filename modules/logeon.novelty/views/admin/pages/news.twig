<div data-admin-page="news">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">News</h4>
            <h6>Gestione novità e comunicazioni pubblicate nel gioco</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-news-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-news-create">
                <i class="bi bi-plus-lg me-1"></i>Nuova novità
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-news-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-news-filter-title" class="form-label mb-1">Titolo</label>
                    <input id="admin-news-filter-title" name="title" type="text" class="form-control" maxlength="100" placeholder="Cerca titolo...">
                </div>
                <div class="col-auto">
                    <label for="admin-news-filter-type" class="form-label mb-1">Tipo</label>
                    <input id="admin-news-filter-type" name="type" type="text" class="form-control" maxlength="60" placeholder="Tipo...">
                </div>
                <div class="col-auto">
                    <label for="admin-news-filter-published" class="form-label mb-1">Pubblicata</label>
                    <select id="admin-news-filter-published" name="is_published" class="form-select">
                        <option value="" selected>Tutte</option>
                        <option value="1">Si</option>
                        <option value="0">No</option>
                    </select>
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/news">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-news"></div>

    {% include 'admin/modals/news.twig' %}
</div>
