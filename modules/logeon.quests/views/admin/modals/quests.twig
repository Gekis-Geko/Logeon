                        <label class="form-label">Operatore</label>
                        <select class="form-select" name="operator">
                            <option value="eq">Uguale (=)</option>
                            <option value="ne">Diverso (&ne;)</option>
                            <option value="in">Incluso in</option>
                            <option value="not_in">Escluso da</option>
                            <option value="gt">Maggiore di (&gt;)</option>
                            <option value="gte">Maggiore o uguale (&ge;)</option>
                            <option value="lt">Minore di (&lt;)</option>
                            <option value="lte">Minore o uguale (&le;)</option>
                            <option value="contains">Contiene</option>
                        </select>
                    </div>
