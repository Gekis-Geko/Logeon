                        <label class="form-label">Modalita</label>
                        <select class="form-select" name="evaluation_mode">
                            <option value="all_required">Tutte necessarie</option>
                            <option value="any_required">Almeno una</option>
                            <option value="blocking">Bloccante</option>
                            <option value="optional">Opzionale</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-2">
                        <label class="form-label">Attiva</label>
                        <select class="form-select" name="is_active">
                            <option value="1">Si</option>
                            <option value="0">No</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Campo payload (guidato)</label>
                        <select class="form-select" name="field_key_preset" data-role="admin-quest-condition-field-key-preset">
                            <option value="">Nessun campo</option>
                            <option value="event_type">Tipo evento</option>
                            <option value="status">Stato</option>
                            <option value="phase">Fase</option>
                            <option value="membership_action">Azione membership</option>
                            <option value="member_role">Ruolo membro</option>
                            <option value="map_id">Mappa</option>
                            <option value="location_id">Luogo</option>
                            <option value="custom">Altro (avanzato)</option>
                        </select>
                        <input type="text" class="form-control mt-2 d-none" name="field_key_custom" maxlength="120" placeholder="Campo personalizzato...">
                        <input type="hidden" name="field_key" value="">
                    </div>
                    <div class="col-12 col-md-8">
                        <label class="form-label">Valore payload (guidato)</label>
                        <select class="form-select" name="field_value_preset" data-role="admin-quest-condition-value-preset">
                            <option value="">Nessun valore</option>
                            <option value="active">Attivo</option>
                            <option value="completed">Completato</option>
                            <option value="failed">Fallito</option>
                            <option value="scheduled">Pianificato</option>
                            <option value="cancelled">Annullato</option>
                            <option value="joined">Aderisce</option>
                            <option value="left">Ha lasciato</option>
                            <option value="role_changed">Ruolo cambiato</option>
                            <option value="custom">Altro (avanzato)</option>
                        </select>
                        <input type="text" class="form-control mt-2 d-none" name="field_value_custom" maxlength="255" placeholder="Valore personalizzato...">
                        <input type="hidden" name="field_value" value="">
                        <div class="form-text">Per operatori <code>in</code> e <code>not_in</code> usa valori separati da virgola nel campo avanzato.</div>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-action="admin-quest-condition-reset">Reset</button>
                        <button type="button" class="btn btn-primary" data-action="admin-quest-condition-save">Salva condizione</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

