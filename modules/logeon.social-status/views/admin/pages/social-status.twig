<div data-admin-page="social-status">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <header class="mt-3">
            <h4 class="display-6">Stati sociali</h4>
            <h6>Gestione stati sociali, soglie di fama e privilegi associati</h6>
        </header>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="admin-social-status-reload">
                <i class="bi bi-arrow-clockwise me-1"></i>Aggiorna
            </button>
            <button type="button" class="btn btn-sm btn-primary" data-action="admin-social-status-create">
                <i class="bi bi-plus-lg me-1"></i>Nuovo stato
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form id="admin-social-status-filters" class="row g-2 align-items-end" autocomplete="off" novalidate>
                <div class="col-auto">
                    <label for="admin-social-status-filter-name" class="form-label mb-1">Nome</label>
                    <input id="admin-social-status-filter-name" name="name" type="text" class="form-control" maxlength="120" placeholder="Nome stato">
                </div>
                <div class="d-flex gap-2 col-auto">
                    <a class="btn btn-sm btn-outline-secondary" href="/admin/social-status">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div id="grid-admin-social-status"></div>

    {% include 'admin/modals/social-status.twig' %}
</div>

